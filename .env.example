# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth.js
AUTH_SECRET=secret-to-change-with-a-real-secret
AUTH_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://culturando:culturando@127.0.0.1:5433/culturando

# Email verification
# Use EMAIL_PROVIDER=console in local development to print verification links in the server logs.
# Use EMAIL_PROVIDER=resend to send real transactional emails through Resend.
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM="Culturando <onboarding@resend.dev>"

# Cloudflare R2 book cover storage
# If any required value is missing, the app falls back to local storage in apps/web/public/uploads/book-covers.
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=
