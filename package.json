{
  "name": "@culturando/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "docker compose up -d --wait postgres && pnpm db:postgis && nx dev web",
    "build": "nx build web",
    "start": "nx start web",
    "lint": "nx lint web",
    "graph": "nx graph",
    "affected": "nx affected",
    "biome:check": "biome check .",
    "biome:write": "biome check --write .",
    "biome:format": "biome format --write .",
    "biome:lint": "biome lint .",
    "biome:ci": "biome ci .",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:postgis": "docker compose exec -T postgres psql -U culturando -d culturando -c \"CREATE EXTENSION IF NOT EXISTS postgis;\"",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:seed": "node --env-file=.env packages/db/prisma/seed.mjs",
    "db:studio": "prisma studio --schema packages/db/prisma/schema.prisma"
  },
  "private": true,
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "~16.1.6",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@eslint/js": "^9.8.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "22.6.0",
    "@nx/eslint-plugin": "22.6.0",
    "@nx/js": "22.6.0",
    "@nx/next": "22.6.0",
    "@nx/workspace": "22.6.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "10.4.13",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "nx": "22.6.0",
    "postcss": "^8.5.15",
    "prisma": "^6.19.0",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
