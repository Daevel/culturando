generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum SalutationPreference {
  masculine
  feminine
  neutral
}

enum BookVisibility {
  public
  private
}

enum BookAvailability {
  available
  consultation_only
  loanable
  unavailable
}

enum BookPhysicalCondition {
  new
  good
  worn
  damaged
}

enum BookImageSource {
  user_upload
  external_api
}

enum LoanRequestType {
  consultation
  loan
  info
}

enum LoanRequestStatus {
  pending
  accepted
  rejected
  cancelled
  completed
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  emailVerifiedAt         DateTime?
  name                    String?
  nickname                String?                  @unique
  nicknameUpdatedAt       DateTime?
  salutationPreference    SalutationPreference     @default(neutral)
  passwordHash            String?
  role                    UserRole                 @default(user)
  avatarUrl               String?
  bio                     String?
  addressLabel            String?
  city                    String?
  province                String?
  postalCode              String?
  region                  String?
  isProfilePublic         Boolean                  @default(true)
  books                   Book[]
  emailVerificationTokens EmailVerificationToken[]
  sentLoanRequests        LoanRequest[]            @relation("LoanRequestRequester")
  receivedLoanRequests    LoanRequest[]            @relation("LoanRequestOwner")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  @@index([role])
  @@index([nickname])
  @@index([emailVerifiedAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Book {
  id                String                @id @default(cuid())
  ownerId           String
  owner             User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title             String
  author            String
  isbn              String?
  description       String?
  publisher         String?
  publishedYear     Int?
  language          String?
  category          String?
  availability      BookAvailability      @default(available)
  visibility        BookVisibility        @default(public)
  physicalCondition BookPhysicalCondition @default(good)
  location          BookLocation?
  images            BookImage[]
  stats             BookStats?
  loanRequests      LoanRequest[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([ownerId])
  @@index([isbn])
  @@index([title])
  @@index([author])
  @@index([availability])
  @@index([visibility])
}

model BookStats {
  id        String   @id @default(cuid())
  bookId    String   @unique
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([viewCount])
}

model BookLocation {
  id                   String   @id @default(cuid())
  bookId               String   @unique
  book                 Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  addressLabel         String
  city                 String?
  province             String?
  region               String?
  country              String   @default("Italia")
  latitude             Float?
  longitude            Float?
  publicLatitude       Float?
  publicLongitude      Float?
  accuracyRadiusMeters Int      @default(750)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([city])
  @@index([province])
  @@index([region])
  @@index([country])
}

model BookImage {
  id           String          @id @default(cuid())
  bookId       String
  book         Book            @relation(fields: [bookId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  source       BookImageSource @default(user_upload)
  alt          String?
  isPrimary    Boolean         @default(false)
  createdAt    DateTime        @default(now())

  @@index([bookId])
  @@index([source])
  @@index([isPrimary])
}

model LoanRequest {
  id          String            @id @default(cuid())
  bookId      String
  book        Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  requesterId String
  requester   User              @relation("LoanRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User              @relation("LoanRequestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  type        LoanRequestType   @default(consultation)
  status      LoanRequestStatus @default(pending)
  message     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([bookId])
  @@index([requesterId])
  @@index([ownerId])
  @@index([status])
  @@index([type])
}
